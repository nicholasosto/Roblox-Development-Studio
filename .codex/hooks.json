{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.project-system/tools/guard.mjs\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.project-system/tools/validate.mjs\" --summary"
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/tools/check-dashboard-drift.mjs\" --quiet"
          }
        ]
      }
    ]
  }
}
