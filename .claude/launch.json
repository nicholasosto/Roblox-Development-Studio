{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "command-center",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--dir", "apps/command-center", "run", "dev"],
      "autoPort": true,
      "port": 5176
    },
    {
      "name": "previews-static",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "exec python3 -m http.server \"${PORT:-4319}\" --bind 127.0.0.1 --directory previews"],
      "autoPort": true,
      "port": 4319
    }
  ]
}
